ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
DOFBOT_SERIAL_DEVICE=/dev/ttyUSB0
DOFBOT_CAMERA_DEVICE=/dev/video0
DOFBOT_CAMERA_WIDTH=640
DOFBOT_CAMERA_HEIGHT=480
DOFBOT_CAMERA_FPS=15
ENABLE_FACE_DETECTION=1
ENABLE_FACE_MESH=0
ENABLE_POSE=0
DOFBOT_ARM_LIB_DIR=/opt/ros/overlay_ws/third_party/Arm_Lib
